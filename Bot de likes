CREATE TABLE users (
 id SERIAL PRIMARY KEY,
 telegram_id BIGINT UNIQUE,
 nick TEXT,
 likes_enviados INT DEFAULT 0,
 vip BOOLEAN DEFAULT FALSE
);

CREATE TABLE logs (
 id SERIAL PRIMARY KEY,
 user_id INT REFERENCES users(id),
 quantidade INT,
 data TIMESTAMP DEFAULT NOW()
);

CREATE TABLE admin (
 id SERIAL PRIMARY KEY,
 username TEXT UNIQUE,
 password TEXT
);
