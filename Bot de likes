{
  "name": "ff-dashboard-bot",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": { "start": "node index.js" },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.4.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.61.0",
    "pg": "^8.11.3"
  }
}
const { Pool } = require('pg');
const pool = new Pool({
  connectionString: process.env.DATABASE_URL,
  ssl: { rejectUnauthorized: false }
});
module.exports = pool;

const express = require('express');
const TelegramBot = require('node-telegram-bot-api');
const pool = require('./db');
const cron = require('node-cron');

const app = express();
app.use(express.json());
app.use(express.static('public'));

const bot = new TelegramBot(process.env.TOKEN, { polling: true });

// Anti-spam
let ultimaAcao = {};

// Função para calcular nível
function getNivel(likes) {
    if (likes >= 1000) return "💎 Diamante";
    if (likes >= 501) return "🏅 Ouro";
    if (likes >= 101) return "🥈 Prata";
    return "🥉 Bronze";
}

// Comando start
bot.onText(/\/start/, async (msg) => {
    const { id, first_name } = msg.from;
    await pool.query(
        `INSERT INTO users (telegram_id, nick) VALUES ($1,$2) ON CONFLICT (telegram_id) DO NOTHING`,
        [id, first_name]
    );
    bot.sendMessage(id, `🔥 Olá ${first_name}, seu sistema de likes está ativo!`);
});

// Comando enviar
bot.onText(/\/enviar (\d+)/, async (msg, match) => {
    const telegramId = msg.from.id;
    const quantidade = parseInt(match[1]);

    if (ultimaAcao[telegramId] && Date.now() - ultimaAcao[telegramId] < 5000)
        return bot.sendMessage(telegramId, "⚠️ Aguarde 5 segundos antes de enviar novamente!");
    ultimaAcao[telegramId] = Date.now();

    const userQuery = await pool.query("SELECT * FROM users WHERE telegram_id=$1", [telegramId]);
    if (!userQuery.rows.length) return;

    let user = userQuery.rows[0];
    let limite = user.vip ? 600 : 300;

    if (user.likes_enviados + quantidade > limite)
        return bot.sendMessage(telegramId, "❌ Limite diário atingido!");

    await pool.query("UPDATE users SET likes_enviados = likes_enviados + $1 WHERE telegram_id=$2", [quantidade, telegramId]);
    await pool.query("INSERT INTO logs (user_id, quantidade) VALUES ($1,$2)", [user.id, quantidade]);

    const antes = user.likes_enviados;
    const depois = user.likes_enviados + quantidade;
    const nivel = getNivel(depois);

    bot.sendMessage(telegramId, `
👑 SEUS LIKES FORAM ENVIADOS COM SUCESSO

👤 Jogador → ${user.nick}
🏆 Level → ${nivel}
🎯 Likes Enviados → ${quantidade}
📉 Antes → ${antes}
📈 Depois → ${depois}
🔑 Limites → ${depois}/${limite}
🌐 Região → 🇧🇷 BR
💬 Sistema → Requisição
`);
});

// Reset diário automático
cron.schedule('0 0 * * *', async () => {
    await pool.query("UPDATE users SET likes_enviados = 0");
    console.log("Reset diário executado!");
});

// Servir painel mobile
app.listen(process.env.PORT || 3000, () => console.log("Servidor online"));
<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard Mobile</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
body { background:#111; color:#fff; font-family:Arial; margin:0; }
header { background:gold; color:#111; padding:15px; text-align:center; font-weight:bold; }
.container { padding:15px; }
.card { background:#1c1c1c; padding:15px; border-radius:12px; margin-bottom:15px; }
ul { list-style:none; padding:0; }
li { padding:5px 0; border-bottom:1px solid #333; }
canvas { width:100% !important; max-height:250px; }
button { width:100%; padding:12px; background:gold; color:#111; border:none; border-radius:8px; font-weight:bold; margin-top:10px; }
</style>
</head>
<body>

<header>👑 Dashboard Mobile</header>

<div class="container">
<div class="card">
<h3>📊 Crescimento Diário</h3>
<canvas id="grafico"></canvas>
</div>

<div class="card">
<h3>🏆 Ranking Top 5</h3>
<ul id="ranking"></ul>
</div>
</div>

<script>
async function loadData() {
    const res = await fetch('/admin/dados');
    const data = await res.json();

    new Chart(document.getElementById('grafico'), {
        type:'line',
        data:{ labels:data.datas, datasets:[{ label:'Likes por Dia', data:data.likes, borderColor:'gold', backgroundColor:'rgba(255,215,0,0.2)', fill:true, tension:0.3 }] },
        options:{ responsive:true }
    });

    const ranking = document.getElementById('ranking');
    ranking.innerHTML='';
    data.top.forEach(u=>{ ranking.innerHTML += `<li>👤 ${u.nick} - 🎯 ${u.likes_enviados}</li>` });
}

loadData();
</script>

</body>
</html>
